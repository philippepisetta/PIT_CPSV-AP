datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// 1. Agent / Organisation (Competent Authority / Acteur)
model Organization {
  id                     Int                   @id @default(autoincrement())
  uri                    String?               @unique
  name                   String
  description            String?               @db.Text
  code                   String?
  type                   String? // ex: Cluster, Pôle de compétitivité, Université, Centre de recherche, Administration, Opérateur public, Association, Financeur
  createdAt              DateTime              @default(now())
  updatedAt              DateTime              @updatedAt
  services               PublicService[]
  ecosystems             Ecosystem[]           @relation("EcosystemActors")
  deliveries             ServiceDelivery[]
  collectiveDeliveries   CollectiveDelivery[]
  leadMissions           SecondLineMission[]   @relation("SecondLineLead")
  participatingMissions  SecondLineMission[]   @relation("SecondLineOperators")
  interventions          Intervention[]        @relation("OrganizationInterventions")
  ecosystemMemberships   EcosystemMembership[]
  datasets               Dataset[]
  activitiesNew          Activity[]            @relation("ActivityOperator")
  activitiesMobilizedNew Activity[]            @relation("ActivityOperatorsNew")

  // Nouvelles relations Strategic Governance
  strategies               Strategy[]                @relation("StrategyOwner")
  programs                 Program[]                 @relation("ProgramOwner")
  initiatives              Initiative[]              @relation("InitiativeLead")
  programParticipations    ProgramParticipation[]
  initiativeParticipations InitiativeParticipation[]

  projects                 Project[]                  @relation("ProjectOrganizations")
  transformationDimensions TransformationDimension[]  @relation("OrganizationTransformations")
  strategicDomains         StrategicDomainDimension[] @relation("OrganizationStrategicDomains")
  capabilities             CapabilityDimension[]      @relation("OrganizationCapabilities")
  impacts                  ImpactDimension[]          @relation("OrganizationImpacts")
  knowledges               KnowledgeDimension[]       @relation("OrganizationKnowledges")

  member Member?

  // vNext back-references
  risks                Risk[]                   @relation("OrganizationRisks")
  riskAssessments      RiskAssessment[]         @relation("OrgRiskAssessments")
  resilienceProfile    ResilienceProfile?       @relation("OrgResilienceProfile")
  resilienceImpacts    ResilienceImpact[]       @relation("OrgResilienceImpacts")
  impactAssessments    ImpactAssessment[]       @relation("OrgImpactAssessments")
  dependencies         Dependency[]             @relation("OrgDependencies")
  vulnerabilities      Vulnerability[]          @relation("OrgVulnerabilities")
  indicators           TerritorialIndicator[]   @relation("OrgIndicators")
  observations         TerritorialObservation[] @relation("OrgObservations")
  assets               TerritorialAsset[]       @relation("OrgAssets")
  capacities           OrganizationalCapacity[] @relation("OrgCapacities")
  dataSources          PitDataSource[]          @relation("OrgDataSources")
  recommendations      PitRecommendation[]      @relation("OrgRecommendations")
  supplierLinks        SupplyChainLink[]        @relation("SupplierLinks")
  buyerLinks           SupplyChainLink[]        @relation("BuyerLinks")
  eventImpacts         TerritorialEventImpact[] @relation("OrgEventImpacts")

  @@map("organizations")
}

// 2. Service Public (Core Concept - CPSV-AP)
model PublicService {
  id          Int      @id @default(autoincrement())
  uri         String?  @unique
  name        String // dct:title
  description String?  @db.Text // dct:description
  code        String? // Code métier unique (ex: S-DIGITAL-DIAG)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  organizationId Int
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  channels             Channel[]        @relation("ServiceChannels")
  targetAudiences      TargetAudience[] @relation("ServiceAudiences")
  businessEvents       BusinessEvent[]  @relation("ServiceBusinessEvents")
  lifeEvents           LifeEvent[]      @relation("ServiceLifeEvents")
  requirements         Requirement[]
  outputs              Output[] // Livrables attendus (théoriques)
  activitiesNew        Activity[]       @relation("ServiceActivitiesNew")
  capabilitiesNew      Capability[]     @relation("ServiceCapabilitiesNew")
  outcomes             Outcome[] // Résultats attendus (théoriques)
  costs                Cost[]
  contactPoints        ContactPoint[]
  rules                Rule[]
  criterions           Criterion[]
  catalogues           Catalogue[]      @relation("CatalogueServices")
  supportsBusinessNeed BusinessNeed[]   @relation("ServiceNeeds")

  // Nouveaux Référentiels Relationnels
  challenges        BusinessChallenge[]   @relation("ServiceChallenges")
  filieresS3        StrategicValueChain[] @relation("ServiceValueChains")
  impactedFunctions EnterpriseFunction[]  @relation("ServiceFunctions")
  stages            ValueChainStage[]     @relation("ServiceStages")

  journeyStages        JourneyStage[]       @relation("StageServices")
  deliveries           ServiceDelivery[]
  collectiveDeliveries CollectiveDelivery[]
  secondLineMissions   SecondLineMission[]
  ecosystems           Ecosystem[]          @relation("EcosystemServices")
  impacts              Json?

  interventionLevelId Int?
  interventionLevel   InterventionLevel? @relation(fields: [interventionLevelId], references: [id], onDelete: SetNull)

  interventionId Int?          @unique
  intervention   Intervention? @relation(fields: [interventionId], references: [id], onDelete: SetNull)

  knowledgeAssets KnowledgeAsset[] @relation("ServiceKnowledgeAssets")
  eventResources  EventResource[]  @relation("ServiceEvents")

  // Nouvelles relations Strategic Governance
  initiatives        Initiative[]        @relation("InitiativeServices")
  fundingInstruments FundingInstrument[] @relation("ServiceFunding")

  transformationDimensions TransformationDimension[]  @relation("ServiceTransformations")
  strategicDomains         StrategicDomainDimension[] @relation("ServiceStrategicDomains")
  capabilities             CapabilityDimension[]      @relation("ServiceCapabilities")
  impactDimensions         ImpactDimension[]          @relation("ServiceImpacts")
  knowledges               KnowledgeDimension[]       @relation("ServiceKnowledges")

  memberServices     MemberService[]
  valueChainSegments ValueChainSegment[]
  ecosystemChallenges EcosystemChallenge[]

  // vNext back-references
  policyMeasures    PolicyMeasure[]          @relation("PolicyMeasureServices")
  resilienceMeasures ResilienceMeasure[]     @relation("ResilienceServiceMeasures")
  observations      TerritorialObservation[] @relation("ServiceObservations")
  recommendations   PitRecommendation[]      @relation("ServiceRecommendations")
  vulnerabilities   Vulnerability[]          @relation("VulnerabilityMitigations")

  @@index([organizationId])
  @@map("public_services")
}

// 3. Canal d'accès (Channel)
model Channel {
  id             Int             @id @default(autoincrement())
  uri            String?         @unique
  name           String
  description    String?         @db.Text
  code           String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  publicServices PublicService[] @relation("ServiceChannels")

  @@map("channels")
}

// 4. Exigence / Condition d'accès (Requirement)
model Requirement {
  id          Int      @id @default(autoincrement())
  uri         String?  @unique
  name        String
  description String?  @db.Text
  code        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  publicServiceId Int
  publicService   PublicService @relation(fields: [publicServiceId], references: [id], onDelete: Cascade)
  evidences       Evidence[]

  @@map("requirements")
}

// 5. Preuve / Document justificatif (Evidence)
model Evidence {
  id          Int      @id @default(autoincrement())
  uri         String?  @unique
  name        String
  description String?  @db.Text
  code        String?
  file        String? // Chemin d'accès ou nom du fichier réel
  url         String? // URL de la preuve en ligne (ex: Vercel blob, drive)
  type        String? // Type de preuve (ex: PDF, Screenshot, Rapport, Contrat)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  requirementId Int?
  requirement   Requirement? @relation(fields: [requirementId], references: [id], onDelete: Cascade)

  serviceDeliveryId Int?
  serviceDelivery   ServiceDelivery? @relation(fields: [serviceDeliveryId], references: [id], onDelete: Cascade)

  collectiveDeliveryId Int?
  collectiveDelivery   CollectiveDelivery? @relation(fields: [collectiveDeliveryId], references: [id], onDelete: Cascade)

  secondLineMissionId Int?
  secondLineMission   SecondLineMission? @relation(fields: [secondLineMissionId], references: [id], onDelete: Cascade)
  activityId          Int?
  activity            Activity?          @relation(fields: [activityId], references: [id], onDelete: Cascade)

  status String @default("PENDING") // PENDING, APPROVED, REJECTED

  @@map("evidences")
}

// 6. Livrable théorique attendu (Output)
model Output {
  id          Int      @id @default(autoincrement())
  uri         String?  @unique
  name        String
  description String?  @db.Text
  code        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  publicServiceId Int
  publicService   PublicService @relation(fields: [publicServiceId], references: [id], onDelete: Cascade)

  @@map("outputs")
}

// 6b. Résultat théorique attendu (Outcome)
model Outcome {
  id          Int      @id @default(autoincrement())
  uri         String?  @unique
  name        String
  description String?  @db.Text
  code        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  publicServiceId Int
  publicService   PublicService @relation(fields: [publicServiceId], references: [id], onDelete: Cascade)

  contributions StrategicContribution[]
  ecosystemChallenges EcosystemChallenge[]

  @@map("outcomes")
}

// 7. Événement professionnel (BusinessEvent)
model BusinessEvent {
  id             Int             @id @default(autoincrement())
  uri            String?         @unique
  name           String
  description    String?         @db.Text
  code           String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  publicServices PublicService[] @relation("ServiceBusinessEvents")

  @@map("business_events")
}

// 8. Événement de vie (LifeEvent)
model LifeEvent {
  id             Int             @id @default(autoincrement())
  uri            String?         @unique
  name           String
  description    String?         @db.Text
  code           String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  publicServices PublicService[] @relation("ServiceLifeEvents")

  @@map("life_events")
}

// 9. Public Cible (TargetAudience)
model TargetAudience {
  id             Int             @id @default(autoincrement())
  uri            String?         @unique
  name           String
  description    String?         @db.Text
  code           String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  publicServices PublicService[] @relation("ServiceAudiences")

  @@map("target_audiences")
}

// 10. Coût (Cost)
model Cost {
  id          Int      @id @default(autoincrement())
  uri         String?  @unique
  name        String // Libellé (ex: Standard, Gratuit)
  value       Float    @default(0.0)
  currency    String   @default("EUR")
  description String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  publicServiceId Int
  publicService   PublicService @relation(fields: [publicServiceId], references: [id], onDelete: Cascade)

  @@map("costs")
}

// 11. Point de contact (ContactPoint)
model ContactPoint {
  id          Int      @id @default(autoincrement())
  uri         String?  @unique
  name        String
  email       String?
  telephone   String?
  description String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  publicServiceId Int
  publicService   PublicService @relation(fields: [publicServiceId], references: [id], onDelete: Cascade)

  @@map("contact_points")
}

// 12. Critère d'éligibilité (Criterion)
model Criterion {
  id          Int      @id @default(autoincrement())
  uri         String?  @unique
  name        String
  description String?  @db.Text
  code        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  publicServiceId Int
  publicService   PublicService @relation(fields: [publicServiceId], references: [id], onDelete: Cascade)

  @@map("criterions")
}

// 13. Règle / Acte Juridique (Rule)
model Rule {
  id          Int      @id @default(autoincrement())
  uri         String?  @unique
  name        String
  description String?  @db.Text
  code        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  publicServiceId Int
  publicService   PublicService @relation(fields: [publicServiceId], references: [id], onDelete: Cascade)

  @@map("rules")
}

// 14. Catalogue de Références / Dataset
model Catalogue {
  id             Int             @id @default(autoincrement())
  uri            String?         @unique
  name           String
  description    String?         @db.Text
  code           String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  publicServices PublicService[] @relation("CatalogueServices")

  @@map("catalogues")
}

// 15. Bénéficiaire territorial (Beneficiary - Nouveau)
model Beneficiary {
  id             Int     @id @default(autoincrement())
  name           String
  bce            String? @unique
  size           String // ex: TPE, PME, Grande Entreprise, Commune...
  employees      Int?
  revenue        Float?
  location       String
  province       String? // ex: Liège, Namur, Hainaut, Brabant Wallon, Luxembourg
  arrondissement String?
  demand         String? @db.Text

  // Secteurs NACE (Ajustement 1)
  primaryNaceSectorId  Int?
  primaryNaceSector    NaceSector?  @relation("PrimaryNace", fields: [primaryNaceSectorId], references: [id], onDelete: SetNull)
  secondaryNaceSectors NaceSector[] @relation("SecondaryNace")

  // 5 dimensions de maturité (1 à 5)
  maturityDigital    Int? @default(1)
  maturityIa         Int? @default(1)
  maturityCyber      Int? @default(1)
  maturityExport     Int? @default(1)
  maturityDurability Int? @default(1)

  // Relations
  challenges           BusinessChallenge[]   @relation("BeneficiaryChallenges")
  filieresS3           StrategicValueChain[] @relation("BeneficiaryValueChains")
  stages               ValueChainStage[]     @relation("BeneficiaryStages")
  playsRole            EcosystemRole[]       @relation("BeneficiaryRoles")
  needs                BusinessNeed[]        @relation("BeneficiaryNeeds")
  enrolledJourneys     Journey[]             @relation("BeneficiaryJourneys")
  deliveries           ServiceDelivery[]
  collectiveDeliveries CollectiveDelivery[]  @relation("CollectiveDeliveryCompanies")
  actionInstances      ActionInstance[]
  journeyEnrollments   JourneyEnrollment[]

  territoryId Int?
  territory   Territory? @relation(fields: [territoryId], references: [id], onDelete: SetNull)

  // Nouvelles relations Strategic Governance
  engagements             BeneficiaryEngagement[]
  impacts                 Impact[]
  fundingInstruments      FundingInstrument[]     @relation("BeneficiaryFunding")
  projects                Project[]               @relation("BeneficiaryProjects")
  activitiesNew           Activity[]              @relation("BeneficiaryActivitiesNew")
  activitiesCollectiveNew Activity[]              @relation("ActivityCompaniesNew")

  beneficiaryType         String                  @default("ENTREPRISE")
  // CRUD Opérationnels & Interop
  status                  String                  @default("ACTIVE") // ACTIVE, ARCHIVED
  sourceSystem            String?
  sourceAuthority         String?
  lastSyncDate            DateTime?
  contacts                Contact[]
  memberships             CommunityMembership[]
  fundingCalls            FundingCall[]
  vulnerabilities         Vulnerability[] @relation("VulnerabilityBeneficiaries")

  roadmapLogs Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  Member      Member?

  @@index([primaryNaceSectorId])
  @@index([territoryId])
  @@map("beneficiaries")
}

// 16. Secteur NACE (NaceSector - Nouveau)
model NaceSector {
  id                     Int           @id @default(autoincrement())
  uri                    String?       @unique
  code                   String // ex: "24.10"
  name                   String // ex: "Fabrication métallique"
  description            String?       @db.Text
  primaryBeneficiaries   Beneficiary[] @relation("PrimaryNace")
  secondaryBeneficiaries Beneficiary[] @relation("SecondaryNace")
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt

  @@map("nace_sectors")
}

// 17. Défi d'affaires (BusinessChallenge - Nouveau)
/// @deprecated
model BusinessChallenge {
  id            Int             @id @default(autoincrement())
  uri           String?         @unique
  name          String // ex: Digitalisation, IA, Cybersécurité, Export, Décarbonation...
  description   String?         @db.Text
  code          String?
  beneficiaries Beneficiary[]   @relation("BeneficiaryChallenges")
  services      PublicService[] @relation("ServiceChallenges")
  journeys      Journey[]       @relation("JourneyChallenges")
  ecosystems    Ecosystem[]     @relation("EcosystemChallenges")
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@map("business_challenges")
}

// 18. Filière Stratégique S3 (StrategicValueChain - Nouveau)
/// @deprecated
model StrategicValueChain {
  id                 Int                 @id @default(autoincrement())
  uri                String?             @unique
  name               String // ex: Industrie du Futur, Santé, Biotech, Hydrogène...
  description        String?             @db.Text
  code               String?
  beneficiaries      Beneficiary[]       @relation("BeneficiaryValueChains")
  services           PublicService[]     @relation("ServiceValueChains")
  journeys           Journey[]           @relation("JourneyValueChains")
  ecosystems         Ecosystem[]         @relation("EcosystemValueChains")
  needs              BusinessNeed[]      @relation("NeedValueChains")
  secondLineMissions SecondLineMission[] @relation("MissionValueChains")

  // Nouvelles relations Strategic Governance
  strategies  Strategy[]              @relation("StrategyValueChains")
  priorities  StrategicPriority[]     @relation("PriorityValueChains")
  programs    Program[]               @relation("ProgramValueChains")
  measures    Measure[]               @relation("MeasureValueChains")
  initiatives Initiative[]            @relation("InitiativeValueChains")
  engagements BeneficiaryEngagement[] @relation("EngagementValueChains")
  impacts     Impact[]                @relation("ImpactValueChains")

  strategicDomainId Int?
  strategicDomain   StrategicDomainDimension? @relation(fields: [strategicDomainId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("strategic_value_chains")
}

// 19. Fonction d'entreprise (EnterpriseFunction - Nouveau)
model EnterpriseFunction {
  id          Int             @id @default(autoincrement())
  uri         String?         @unique
  name        String // ex: Marketing, Vente, RH, Production, R&D, IT...
  description String?         @db.Text
  code        String?
  services    PublicService[] @relation("ServiceFunctions")
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@map("enterprise_functions")
}

// 20. Maillon Transverse (ValueChainStage)
model ValueChainStage {
  id            Int             @id @default(autoincrement())
  uri           String?         @unique
  name          String // ex: Recherche appliquée, Conception, Production, Maintenance
  category      String // ex: Innovation, Industrialisation, Production, Go-To-Market, Exploitation, Circularité
  description   String?         @db.Text
  beneficiaries Beneficiary[]   @relation("BeneficiaryStages")
  services      PublicService[] @relation("ServiceStages")
  journeys      Journey[]       @relation("JourneyStages")
  needs         BusinessNeed[]  @relation("NeedStages")
  valueChainId  Int?
  valueChain    ValueChain?     @relation(fields: [valueChainId], references: [id], onDelete: SetNull)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@map("value_chain_stages")
}

// 21. Rôle Écosystémique (EcosystemRole)
model EcosystemRole {
  id          Int           @id @default(autoincrement())
  uri         String?       @unique
  name        String
  description String?       @db.Text
  companies   Beneficiary[] @relation("BeneficiaryRoles")
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@map("ecosystem_roles")
}

// 22. Besoin Métier (BusinessNeed)
model BusinessNeed {
  id               Int                   @id @default(autoincrement())
  uri              String?               @unique
  name             String
  description      String?               @db.Text
  beneficiaries    Beneficiary[]         @relation("BeneficiaryNeeds")
  valueChains      StrategicValueChain[] @relation("NeedValueChains")
  valueChainStages ValueChainStage[]     @relation("NeedStages")
  journeys         Journey[]             @relation("JourneyNeeds")
  services         PublicService[]       @relation("ServiceNeeds")
  rule             Json?
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt

  @@map("business_needs")
}

// 23. Écosystème Régional (Ecosystem - Nouveau)
model Ecosystem {
  id          Int     @id @default(autoincrement())
  uri         String? @unique
  name        String // ex: EDIH Wallonia, BioWin
  description String? @db.Text
  mission     String? @db.Text
  territory   String? // ex: Wallonie

  actors             Organization[]        @relation("EcosystemActors")
  services           PublicService[]       @relation("EcosystemServices")
  journeys           Journey[]             @relation("EcosystemJourneys")
  filieresS3         StrategicValueChain[] @relation("EcosystemValueChains")
  challenges         BusinessChallenge[]   @relation("EcosystemChallenges")
  secondLineMissions SecondLineMission[]   @relation("MissionEcosystems")

  typeId              Int?
  type                EcosystemType?        @relation(fields: [typeId], references: [id], onDelete: SetNull)
  memberships         EcosystemMembership[]
  activitiesNew       Activity[]            @relation("ActivityEcosystemsNew")
  activitiesDirectNew Activity[]            @relation("ActivityEcosystemDirectNew")
  knowledgeAssets     KnowledgeAsset[]      @relation("EcosystemKnowledgeAssets")
  eventResources      EventResource[]       @relation("EcosystemEvents")
  actionInstances     ActionInstance[]

  // Nouvelles relations Strategic Governance
  strategies               Strategy[]              @relation("StrategyEcosystems")
  priorities               StrategicPriority[]     @relation("PriorityEcosystems")
  programs                 Program[]               @relation("ProgramEcosystems")
  measures                 Measure[]               @relation("MeasureEcosystems")
  initiatives              Initiative[]            @relation("InitiativeEcosystems")
  territories              Territory[]             @relation("EcosystemTerritories")
  secondLineMissionsDirect SecondLineMission[]     @relation("MissionEcosystemDirect")
  engagements              BeneficiaryEngagement[]

  projects                 Project[]                  @relation("ProjectEcosystems")
  transformationDimensions TransformationDimension[]  @relation("EcosystemTransformations")
  strategicDomains         StrategicDomainDimension[] @relation("EcosystemStrategicDomains")
  capabilities             CapabilityDimension[]      @relation("EcosystemCapabilities")
  impacts                  ImpactDimension[]          @relation("EcosystemImpacts")

  // vNext back-references
  risks                Risk[]                   @relation("EcosystemRisks")
  resilienceProfile    ResilienceProfile?       @relation("EcosystemResilienceProfile")
  resilienceImpacts    ResilienceImpact[]       @relation("EcosystemResilienceImpacts")
  indicators           TerritorialIndicator[]   @relation("EcosystemIndicators")
  observations         TerritorialObservation[] @relation("EcosystemObservations")
  assets               TerritorialAsset[]       @relation("EcosystemAssets")
  capacities           OrganizationalCapacity[] @relation("EcosystemCapacities")
  territorialChallenges TerritorialChallenge[]  @relation("EcosystemChallenges2")

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  Filiere   Filiere[]

  @@map("ecosystems")
}

// 24. Parcours de Transformation (Journey)
model Journey {
  id             Int      @id @default(autoincrement())
  uri            String?  @unique
  // R4 — Raffinement vNext
  code           String?  @unique
  journeyStatus  String?  @default("ACTIVE") // TEMPLATE|ACTIVE|DEPRECATED
  name           String
  provider       String
  objective      String?  @db.Text
  description    String?  @db.Text
  targetAudience String[] // ex: ["PME", "Startup"]

  stages             JourneyStage[]
  companies          Beneficiary[]           @relation("BeneficiaryJourneys")
  filieresS3         StrategicValueChain[]   @relation("JourneyValueChains")
  challenges         BusinessChallenge[]     @relation("JourneyChallenges")
  stagesTransverses  ValueChainStage[]       @relation("JourneyStages")
  needs              BusinessNeed[]          @relation("JourneyNeeds")
  ecosystems         Ecosystem[]             @relation("EcosystemJourneys")
  deliveries         ServiceDelivery[]
  journeyEnrollments JourneyEnrollment[]
  actionInstances    ActionInstance[]
  activitiesNew      Activity[]              @relation("JourneyActivitiesNew")
  engagements        BeneficiaryEngagement[]

  transformationDimensions TransformationDimension[]  @relation("JourneyTransformations")
  strategicDomains         StrategicDomainDimension[] @relation("JourneyStrategicDomains")

  // vNext back-references
  policyMeasures        PolicyMeasure[]       @relation("PolicyMeasureJourneys")
  recommendations       PitRecommendation[]   @relation("RecommendationJourneys")
  territorialChallenges TerritorialChallenge[] @relation("ChallengeJourneys")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("journeys")
}

// 25. Étape de Parcours (JourneyStage)
model JourneyStage {
  id                 Int                 @id @default(autoincrement())
  name               String // ex: Sensibilisation, Diagnostic, Financement...
  position           Int
  // R4 — Raffinement vNext
  stepType           String?  // DIAGNOSTIC|ORIENTATION|SUPPORT|EVALUATION|MONITORING
  expectedOutcome    String?  @db.Text
  journeyId          Int?
  journey            Journey?            @relation(fields: [journeyId], references: [id], onDelete: Cascade)
  services           PublicService[]     @relation("StageServices")
  deliveries         ServiceDelivery[]
  journeyEnrollments JourneyEnrollment[]
  activitiesNew      Activity[]          @relation("JourneyStageActivitiesNew")

  templateId        Int?
  template          JourneyTemplate?  @relation(fields: [templateId], references: [id], onDelete: Cascade)
  instancesProgress JourneyProgress[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("journey_stages")
}

enum ServiceDeliveryStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

