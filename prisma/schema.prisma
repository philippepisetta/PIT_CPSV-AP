  programs             Program[]            @relation("ProgramTransformations")
  projects             Project[]            @relation("ProjectTransformations")
  actionInstances      ActionInstance[]     @relation("ActionTransformations")
  deliveries           ServiceDelivery[]    @relation("DeliveryTransformations")
  collectiveDeliveries CollectiveDelivery[] @relation("CollectiveTransformations")
  secondLineMissions   SecondLineMission[]  @relation("MissionTransformations")
  services             PublicService[]      @relation("ServiceTransformations")
  journeys             Journey[]            @relation("JourneyTransformations")
  ecosystems           Ecosystem[]          @relation("EcosystemTransformations")
  activitiesNew        Activity[]           @relation("ActivityTransformationsNew")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("transformation_dimensions")
}

