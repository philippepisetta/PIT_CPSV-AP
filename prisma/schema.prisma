  code        String  @unique // COMPETITIVENESS, INNOVATION, etc.
  name        String // Compétitivité, Innovation, etc.
  category    String // SDG, GREEN_DEAL, CIRCULAR_WALLONIA, REGIONAL
  description String? @db.Text
  uri         String? @unique

  impacts         Impact[]
