  code        String?  @unique
  name        String
  description String?  @db.Text
  status      String   @default("ACTIVE")

  programs    Program[]             @relation("PriorityPrograms")
  measures    Measure[]             @relation("PriorityMeasures")
  initiatives Initiative[]          @relation("PriorityInitiatives")
  ecosystems  Ecosystem[]           @relation("PriorityEcosystems")
  filieresS3  StrategicValueChain[] @relation("PriorityValueChains")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("strategic_priorities")
}

model Program {
  id                  Int           @id @default(autoincrement())
  code                String?       @unique
  name                String
  description         String?       @db.Text
  ownerOrganizationId Int?
  ownerOrganization   Organization? @relation("ProgramOwner", fields: [ownerOrganizationId], references: [id], onDelete: SetNull)
  startDate           DateTime?
  endDate             DateTime?
  budget              Float?
  status              ProgramStatus @default(PLANNED)

  strategies         Strategy[]             @relation("StrategyPrograms")
  priorities         StrategicPriority[]    @relation("PriorityPrograms")
  measures           Measure[]              @relation("ProgramMeasures")
  ecosystems         Ecosystem[]            @relation("ProgramEcosystems")
  filieresS3         StrategicValueChain[]  @relation("ProgramValueChains")
  territories        Territory[]            @relation("ProgramTerritories")
  participations     ProgramParticipation[]
  fundingInstruments FundingInstrument[]    @relation("ProgramFunding")
  knowledgeAssets    KnowledgeAsset[]       @relation("ProgramKnowledgeAssets")

  projects                 Project[]
  transformationDimensions TransformationDimension[]  @relation("ProgramTransformations")
  strategicDomains         StrategicDomainDimension[] @relation("ProgramStrategicDomains")
  capabilities             CapabilityDimension[]      @relation("ProgramCapabilities")
  impacts                  ImpactDimension[]          @relation("ProgramImpacts")
  knowledges               KnowledgeDimension[]       @relation("ProgramKnowledges")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ecosystemChallenges EcosystemChallenge[]
  mitigatedVulnerabilities Vulnerability[] @relation("ProgramMitigatedVulnerabilities")

  // vNext back-references
  policyMeasures PolicyMeasure[]          @relation("PolicyMeasurePrograms")
  observations   TerritorialObservation[] @relation("ProgramObservations")

