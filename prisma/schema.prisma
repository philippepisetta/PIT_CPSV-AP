  name            String            // Compétitivité, Innovation, etc.
  category        String            // SDG, GREEN_DEAL, CIRCULAR_WALLONIA, REGIONAL
  description     String?           @db.Text
  uri             String?           @unique
  
  impacts         Impact[]
  services        PublicService[]   @relation("ServiceImpacts")
  programs        Program[]         @relation("ProgramImpacts")
  projects        Project[]         @relation("ProjectImpacts")
  actionInstances ActionInstance[]  @relation("ActionImpacts")
  organizations   Organization[]    @relation("OrganizationImpacts")
  ecosystems      Ecosystem[]       @relation("EcosystemImpacts")
  datasets        Dataset[]         @relation("DatasetImpacts")
  knowledgeAssets KnowledgeAsset[]  @relation("AssetImpacts")

