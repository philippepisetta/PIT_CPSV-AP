  riskAssessments      RiskAssessment[]         @relation("TerritoryRiskAssessments")
  resilienceProfile    ResilienceProfile?       @relation("TerritoryResilienceProfile")
  resilienceImpacts    ResilienceImpact[]       @relation("TerritoryResilienceImpacts")
  impactAssessments    ImpactAssessment[]       @relation("TerritoryImpactAssessments")
  indicators           TerritorialIndicator[]   @relation("TerritoryIndicators")
  observations         TerritorialObservation[] @relation("TerritoryObservations")
  assets               TerritorialAsset[]       @relation("TerritoryAssets")
  capacities           OrganizationalCapacity[] @relation("TerritoryCapacities")
  recommendations      PitRecommendation[]      @relation("TerritoryRecommendations")
  criticalInfras       CriticalInfrastructure[] @relation("TerritoryInfras")
  territorialEvents    TerritorialEvent[]       @relation("TerritoryEvents")
  eventImpacts         TerritorialEventImpact[] @relation("TerritoryEventImpacts")
  challenges           TerritorialChallenge[]   @relation("TerritoryChallenges")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("territories")
}

