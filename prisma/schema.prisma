  accuracy     Float
  validity     Float
  consistency  Float
  timeliness   Float
  uniqueness   Float
  traceability Float
  clarity      Float
  availability Float
  overallScore Float

  datasetId Int?     @unique
  dataset   Dataset? @relation(fields: [datasetId], references: [id], onDelete: Cascade)

  knowledgeAssetId Int?            @unique
  knowledgeAsset   KnowledgeAsset? @relation(fields: [knowledgeAssetId], references: [id], onDelete: Cascade)

  indicatorId Int?              @unique
  indicator   OutcomeIndicator? @relation(fields: [indicatorId], references: [id], onDelete: Cascade)

