model TerritorialChallenge {
  id          Int     @id @default(autoincrement())
  code        String? @unique
  name        String
  description String? @db.Text
  category    String  // DECARBONISATION|DIGITAL|INDUSTRIAL|RESILIENCE|SKILLS|CIRCULAR|SOCIAL|GOVERNANCE|HEALTH|FOOD
  horizon     String  @default("MEDIUM") // SHORT|MEDIUM|LONG
  priority    String  @default("HIGH") // CRITICAL|HIGH|MEDIUM|LOW
  status      String  @default("ACTIVE") // IDENTIFIED|ACTIVE|MONITORED|RESOLVED
  uri         String? @unique

  // Hiérarchie
  parentChallengeId Int?
