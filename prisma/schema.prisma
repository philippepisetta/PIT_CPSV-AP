model Strategy {
  id                  Int           @id @default(autoincrement())
  uri                 String?       @unique
  code                String?       @unique
  name                String
  description         String?       @db.Text
  ownerOrganizationId Int?
  ownerOrganization   Organization? @relation("StrategyOwner", fields: [ownerOrganizationId], references: [id], onDelete: SetNull)
  startDate           DateTime?
  endDate             DateTime?
  status              String        @default("ACTIVE") // ex: ACTIVE, DRAFT, COMPLETED
  website             String?

  priorities         StrategicPriority[]
  programs           Program[]             @relation("StrategyPrograms")
  ecosystems         Ecosystem[]           @relation("StrategyEcosystems")
  filieresS3         StrategicValueChain[] @relation("StrategyValueChains")
  fundingInstruments FundingInstrument[]   @relation("StrategyFunding")
  objectives         Objective[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("strategies")
}

