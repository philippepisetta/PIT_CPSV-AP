  secondLineMissions   SecondLineMission[]  @relation("MissionStrategicDomains")
  services             PublicService[]      @relation("ServiceStrategicDomains")
  journeys             Journey[]            @relation("JourneyStrategicDomains")
  ecosystems           Ecosystem[]          @relation("EcosystemStrategicDomains")

