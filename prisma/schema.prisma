  knowledgeAssets KnowledgeAsset[] @relation("AssetKnowledges")
  services        PublicService[]  @relation("ServiceKnowledges")
  projects        Project[]        @relation("ProjectKnowledges")
  actionInstances ActionInstance[] @relation("ActionKnowledges")
  organizations   Organization[]   @relation("OrganizationKnowledges")
  programs        Program[]        @relation("ProgramKnowledges")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("knowledge_dimensions")
}

model DataQualityDimension {
