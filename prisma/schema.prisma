  uri         String? @unique

  services        PublicService[]  @relation("ServiceCapabilities")
  programs        Program[]        @relation("ProgramCapabilities")
  projects        Project[]        @relation("ProjectCapabilities")
  actionInstances ActionInstance[] @relation("ActionCapabilities")
  organizations   Organization[]   @relation("OrganizationCapabilities")
  ecosystems      Ecosystem[]      @relation("EcosystemCapabilities")
  datasets        Dataset[]        @relation("DatasetCapabilities")
  knowledgeAssets KnowledgeAsset[] @relation("AssetCapabilities")

