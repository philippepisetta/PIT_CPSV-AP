  category          String  // ECONOMIC|SOCIAL|ENVIRONMENTAL|ENERGY|INNOVATION|DIGITAL|RESILIENCE|GOVERNANCE
  source            String?
  owner             String?
  frequency         String  @default("ANNUAL") // DAILY|WEEKLY|MONTHLY|QUARTERLY|ANNUAL
  aggregationType   String  @default("LAST") // SUM|AVG|MAX|MIN|COUNT|LAST
  dataType          String  @default("NUMERIC") // NUMERIC|PERCENTAGE|BOOLEAN|TEXT
  // Raffinement R3: calcul composite
  computationType   String  @default("DIRECT") // DIRECT|DERIVED|COMPOSITE|RATIO|TREND|SIMULATION
  formula           String? // Expression ou JSON pour indicateurs composites
  isComposite       Boolean @default(false)
  uri               String? @unique

  parentIndicatorId Int?
  parentIndicator   TerritorialIndicator?  @relation("IndicatorHierarchy", fields: [parentIndicatorId], references: [id], onDelete: SetNull)
  childIndicators   TerritorialIndicator[] @relation("IndicatorHierarchy")

  observations TerritorialObservation[]

  // Relations transversales (Raffinement R2 + modèle complet)
  organizations        Organization[]        @relation("OrgIndicators")
  territories          Territory[]           @relation("TerritoryIndicators")
  filieres             Filiere[]             @relation("FiliereIndicators")
  valueChains          ValueChain[]          @relation("ValueChainIndicators")
  ecosystems           Ecosystem[]           @relation("EcosystemIndicators")
  risks                Risk[]                @relation("RiskIndicators")
  assets               TerritorialAsset[]    @relation("AssetIndicators")
  territorialChallenges TerritorialChallenge[] @relation("ChallengeIndicators")
  challengeObjectives  ChallengeObjective[]  @relation("ObjectiveIndicators")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("territorial_indicators")
}

model TerritorialObservation {
  id              Int     @id @default(autoincrement())
  value           Float?
  textValue       String? @db.Text
  period          String  // "2024", "2024-Q1", "2024-01"
  observedAt      DateTime @default(now())
  source          String?
  confidenceLevel Float?  @default(1.0) // 0-1
  qualityNote     String?

  indicatorId Int
  indicator   TerritorialIndicator @relation(fields: [indicatorId], references: [id], onDelete: Cascade)

  // Raffinement R2: FKs analytiques complètes
  organizationId         Int?
  organization           Organization? @relation("OrgObservations", fields: [organizationId], references: [id], onDelete: SetNull)

  territoryId            Int?
  territory              Territory? @relation("TerritoryObservations", fields: [territoryId], references: [id], onDelete: SetNull)

  programId              Int?
  program                Program? @relation("ProgramObservations", fields: [programId], references: [id], onDelete: SetNull)

  publicServiceId        Int?
  publicService          PublicService? @relation("ServiceObservations", fields: [publicServiceId], references: [id], onDelete: SetNull)

  valueChainId           Int?
  valueChain             ValueChain? @relation("ValueChainObservations", fields: [valueChainId], references: [id], onDelete: SetNull)

  ecosystemId            Int?
  ecosystem              Ecosystem? @relation("EcosystemObservations", fields: [ecosystemId], references: [id], onDelete: SetNull)

  riskId                 Int?
  risk                   Risk? @relation("RiskObservations", fields: [riskId], references: [id], onDelete: SetNull)

  filiereId              Int?
  filiere                Filiere? @relation("FiliereObservations", fields: [filiereId], references: [id], onDelete: SetNull)

  // Raffinement R2: FK TerritorialChallenge
  territorialChallengeId Int?
  territorialChallenge   TerritorialChallenge? @relation("ChallengeObservations", fields: [territorialChallengeId], references: [id], onDelete: SetNull)

  assetId                Int?
  asset                  TerritorialAsset? @relation("AssetObservations", fields: [assetId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([indicatorId, period])
  @@index([organizationId, period])
  @@index([territoryId, period])
  @@map("territorial_observations")
}

