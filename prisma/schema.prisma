  targetValue           Float?
  targetUnit            String?
  targetYear            Int?
  currentValue          Float?
  status                String  @default("NOT_STARTED") // NOT_STARTED|IN_PROGRESS|ACHIEVED|AT_RISK

  territorialChallengeId Int
  territorialChallenge   TerritorialChallenge @relation(fields: [territorialChallengeId], references: [id], onDelete: Cascade)

  indicatorId           Int?
  indicator             TerritorialIndicator? @relation("ObjectiveIndicators", fields: [indicatorId], references: [id], onDelete: SetNull)

  policyObjectiveId     Int?
  policyObjective       PolicyObjective? @relation("ObjectiveChallengeObjectives", fields: [policyObjectiveId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("challenge_objectives")
}

