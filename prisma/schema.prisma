}

model JourneyEnrollment {
  id             Int           @id @default(autoincrement())
  startDate      DateTime      @default(now())
  endDate        DateTime?
  status         String        @default("ENROLLED") // ENROLLED, IN_PROGRESS, COMPLETED, ABANDONED
  completionRate Float         @default(0.0)
  
  beneficiaryId  Int
  beneficiary    Beneficiary   @relation(fields: [beneficiaryId], references: [id], onDelete: Cascade)
  
  journeyId      Int
  journey       Journey       @relation(fields: [journeyId], references: [id], onDelete: Cascade)
  
  currentStageId Int?
  currentStage   JourneyStage? @relation(fields: [currentStageId], references: [id], onDelete: SetNull)

  // Relation inverse pour ServiceDelivery
  deliveries     ServiceDelivery[]
  activitiesNew  Activity[]           @relation("JourneyEnrollmentActivitiesNew")

  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@map("journey_enrollments")
}

model EcosystemType {
  id          Int         @id @default(autoincrement())
  code        String      @unique // EDIH, CLUSTER, POLE_COMPETITIVITE, LIVING_LAB, HUB_INNOVATION, NETWORK, COMMUNITY
  name        String
  description String?     @db.Text
  ecosystems  Ecosystem[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@map("ecosystem_types")
}

model EcosystemMembership {
  id             Int          @id @default(autoincrement())
  role           String       // ex: Coordinateur, Expert, Financeur, Partenaire
  startDate      DateTime     @default(now())
  endDate        DateTime?
  status         String       @default("ACTIVE") // ACTIVE, INACTIVE
  
  ecosystemId    Int
  ecosystem      Ecosystem    @relation(fields: [ecosystemId], references: [id], onDelete: Cascade)
  
  organizationId Int
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@map("ecosystem_memberships")
}

model KnowledgeAsset {
  id                 Int                 @id @default(autoincrement())
  title              String
  type               KnowledgeAssetType  // Enum type
  description        String?             @db.Text
  file               String?
  url                String?
  
  publicServices     PublicService[]     @relation("ServiceKnowledgeAssets")
  ecosystems         Ecosystem[]         @relation("EcosystemKnowledgeAssets")
  secondLineMissions SecondLineMission[] @relation("MissionKnowledgeAssets")
  eventResources     EventResource[]     @relation("EventKnowledgeAssets")

  // Nouvelles relations Strategic Governance
  programs           Program[]           @relation("ProgramKnowledgeAssets")
  initiatives        Initiative[]        @relation("InitiativeKnowledgeAssets")

  capabilities       CapabilityDimension[]     @relation("AssetCapabilities")
  impacts            ImpactDimension[]         @relation("AssetImpacts")
  knowledges         KnowledgeDimension[]       @relation("AssetKnowledges")
  dataQuality        DataQualityDimension?
  activitiesNew      Activity[]           @relation("ActivityKnowledgeAssetsNew")

  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  @@map("knowledge_assets")
}

model Dataset {
  id                 Int          @id @default(autoincrement())
  title              String
  description        String?      @db.Text
  themes             Json?        // ex: ["IA", "Cybersécurité"]
  keywords           Json?        // ex: ["PME", "Données"]
  qualityScore       Float        @default(5.0)
  updateFrequency    String       // ex: Journalier, Hebdomadaire, Mensuel, Annuel
  
  ownerOrganizationId Int
  ownerOrganization   Organization @relation(fields: [ownerOrganizationId], references: [id], onDelete: Cascade)

  capabilities       CapabilityDimension[]     @relation("DatasetCapabilities")
  impacts            ImpactDimension[]         @relation("DatasetImpacts")
  knowledges         KnowledgeDimension[]       @relation("DatasetKnowledges")
  dataQuality        DataQualityDimension?

  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  @@map("datasets")
}

model Territory {
  id                Int                   @id @default(autoincrement())
  uri               String?               @unique
  code              String?               @unique
  name              String
  type              TerritoryType         // Enum type
  description       String?               @db.Text
  
  parentTerritoryId Int?
  parentTerritory   Territory?            @relation("TerritoryHierarchy", fields: [parentTerritoryId], references: [id], onDelete: SetNull)
  childTerritories  Territory[]           @relation("TerritoryHierarchy")

  beneficiaries     Beneficiary[]
  programs          Program[]             @relation("ProgramTerritories")
  initiatives       Initiative[]          @relation("InitiativeTerritories")
  ecosystems        Ecosystem[]           @relation("EcosystemTerritories")
  engagements       BeneficiaryEngagement[]
  impacts           Impact[]

  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  @@map("territories")
}

model EventResource {
  id                  Int                  @id @default(autoincrement())
  uri                 String?              @unique
  title               String
  description         String?              @db.Text
  type                String               // salon, conférence, atelier, appel public, réunion d'écosystème, lancement de programme
  startDate           DateTime             @default(now())
  endDate             DateTime?
  location            String?
  
  publicServices      PublicService[]      @relation("ServiceEvents")
  collectiveDeliveries CollectiveDelivery[]
  ecosystems          Ecosystem[]          @relation("EcosystemEvents")
  knowledgeAssets     KnowledgeAsset[]     @relation("EventKnowledgeAssets")
  activitiesNew       Activity[]           @relation("EventActivitiesNew")

  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  @@map("event_resources")
}

// ==========================================
// Strategic Governance Enums
// ==========================================

enum ParticipationRole {
  COORDINATOR
  PARTNER
  FUNDER
  OPERATOR
  EXPERT
  CONTRIBUTOR
}

enum ProgramStatus {
  PLANNED
  ACTIVE
  COMPLETED
  CANCELLED
}

enum InitiativeStatus {
  PLANNED
  ACTIVE
  COMPLETED
  CANCELLED
}

enum TerritoryType {
  REGION
  PROVINCE
  ARRONDISSEMENT
  COMMUNE
  ECONOMIC_BASIN
  INNOVATION_DISTRICT
}

enum KnowledgeAssetType {
  GUIDE
  REFERENTIAL
  BENCHMARK
  STUDY
  PUBLICATION
  METHODOLOGY
  TOOLKIT
}

// ==========================================
// Strategic Governance Models
// ==========================================

model Strategy {
  id                  Int                   @id @default(autoincrement())
  uri                 String?               @unique
  code                String?               @unique
  name                String
  description         String?               @db.Text
  ownerOrganizationId Int?
  ownerOrganization   Organization?         @relation("StrategyOwner", fields: [ownerOrganizationId], references: [id], onDelete: SetNull)
  startDate           DateTime?
  endDate             DateTime?
  status              String                @default("ACTIVE") // ex: ACTIVE, DRAFT, COMPLETED
  website             String?

  priorities          StrategicPriority[]
  programs            Program[]             @relation("StrategyPrograms")
  ecosystems          Ecosystem[]           @relation("StrategyEcosystems")
  filieresS3          StrategicValueChain[] @relation("StrategyValueChains")
  fundingInstruments  FundingInstrument[]   @relation("StrategyFunding")
  objectives          Objective[]

  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt

  @@map("strategies")
}

/// @deprecated
model StrategicPriority {
  id          Int                   @id @default(autoincrement())
  strategyId  Int
  strategy    Strategy              @relation(fields: [strategyId], references: [id], onDelete: Cascade)
  code        String?               @unique
  name        String
  description String?               @db.Text
  status      String                @default("ACTIVE")

  programs    Program[]             @relation("PriorityPrograms")
  measures    Measure[]             @relation("PriorityMeasures")
  initiatives Initiative[]          @relation("PriorityInitiatives")
  ecosystems  Ecosystem[]           @relation("PriorityEcosystems")
  filieresS3  StrategicValueChain[] @relation("PriorityValueChains")

  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  @@map("strategic_priorities")
}

model Program {
  id                  Int                   @id @default(autoincrement())
  code                String?               @unique
  name                String
  description         String?               @db.Text
  ownerOrganizationId Int?
  ownerOrganization   Organization?         @relation("ProgramOwner", fields: [ownerOrganizationId], references: [id], onDelete: SetNull)
  startDate           DateTime?
  endDate             DateTime?
  budget              Float?
  status              ProgramStatus         @default(PLANNED)

  strategies          Strategy[]            @relation("StrategyPrograms")
  priorities          StrategicPriority[]   @relation("PriorityPrograms")
  measures            Measure[]             @relation("ProgramMeasures")
  ecosystems          Ecosystem[]           @relation("ProgramEcosystems")
  filieresS3          StrategicValueChain[] @relation("ProgramValueChains")
  territories         Territory[]           @relation("ProgramTerritories")
  participations      ProgramParticipation[]
  fundingInstruments  FundingInstrument[]   @relation("ProgramFunding")
  knowledgeAssets     KnowledgeAsset[]      @relation("ProgramKnowledgeAssets")

  projects            Project[]
  transformationDimensions TransformationDimension[] @relation("ProgramTransformations")
  strategicDomains         StrategicDomainDimension[] @relation("ProgramStrategicDomains")
  capabilities             CapabilityDimension[]     @relation("ProgramCapabilities")
  impacts                  ImpactDimension[]         @relation("ProgramImpacts")
  knowledges               KnowledgeDimension[]       @relation("ProgramKnowledges")

  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt

  @@map("programs")
}

/// @deprecated
model Measure {
  id                 Int                   @id @default(autoincrement())
  code               String?               @unique
  name               String
  description        String?               @db.Text
  budget             Float?
  status             String                @default("ACTIVE")

  programs           Program[]             @relation("ProgramMeasures")
  priorities         StrategicPriority[]   @relation("PriorityMeasures")
  initiatives        Initiative[]
  ecosystems         Ecosystem[]           @relation("MeasureEcosystems")
  filieresS3         StrategicValueChain[] @relation("MeasureValueChains")
  fundingInstruments FundingInstrument[]   @relation("MeasureFunding")

  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt

  @@map("measures")
}

model Initiative {
  id                 Int                   @id @default(autoincrement())
  measureId          Int
  measure            Measure               @relation(fields: [measureId], references: [id], onDelete: Cascade)
  code               String?               @unique
  name               String
  description        String?               @db.Text
  leadOrganizationId Int?
  leadOrganization   Organization?         @relation("InitiativeLead", fields: [leadOrganizationId], references: [id], onDelete: SetNull)
  startDate          DateTime?
  endDate            DateTime?
  status             InitiativeStatus      @default(PLANNED)

  priorities         StrategicPriority[]   @relation("PriorityInitiatives")
  ecosystems         Ecosystem[]           @relation("InitiativeEcosystems")
  filieresS3         StrategicValueChain[] @relation("InitiativeValueChains")
  territories        Territory[]           @relation("InitiativeTerritories")
  publicServices     PublicService[]       @relation("InitiativeServices")
  participations     InitiativeParticipation[]
  deliveries         ServiceDelivery[]
  collectiveDeliveries CollectiveDelivery[]
  secondLineMissions SecondLineMission[]
  engagements        BeneficiaryEngagement[]
  fundingInstruments FundingInstrument[]   @relation("InitiativeFunding")
  knowledgeAssets    KnowledgeAsset[]      @relation("InitiativeKnowledgeAssets")

  projects           Project[]
  activities         Activity[]

  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt

  @@map("initiatives")
}

model ProgramParticipation {
  id             Int               @id @default(autoincrement())
  programId      Int
  program        Program           @relation(fields: [programId], references: [id], onDelete: Cascade)
  organizationId Int
  organization   Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  role           ParticipationRole
  startDate      DateTime          @default(now())
  endDate        DateTime?
  status         String            @default("ACTIVE") // ACTIVE, INACTIVE

  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@map("program_participations")
}

model InitiativeParticipation {
  id             Int               @id @default(autoincrement())
  initiativeId   Int
  initiative     Initiative        @relation(fields: [initiativeId], references: [id], onDelete: Cascade)
  organizationId Int
  organization   Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  role           ParticipationRole
  startDate      DateTime          @default(now())
  endDate        DateTime?
  status         String            @default("ACTIVE") // ACTIVE, INACTIVE

  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@map("initiative_participations")
}

model BeneficiaryEngagement {
  id            Int                   @id @default(autoincrement())
  beneficiaryId Int
  beneficiary   Beneficiary           @relation(fields: [beneficiaryId], references: [id], onDelete: Cascade)
  journeyId     Int?
  journey       Journey?              @relation(fields: [journeyId], references: [id], onDelete: SetNull)
  initiativeId  Int?
  initiative    Initiative?           @relation(fields: [initiativeId], references: [id], onDelete: SetNull)
  ecosystemId   Int?
  ecosystem     Ecosystem?            @relation(fields: [ecosystemId], references: [id], onDelete: SetNull)
  territoryId   Int?
  territory     Territory?            @relation(fields: [territoryId], references: [id], onDelete: SetNull)
  title         String
  objective     String?               @db.Text
  status        String                @default("PLANNED") // PLANNED, IN_PROGRESS, COMPLETED, CANCELLED
  startDate     DateTime              @default(now())
  endDate       DateTime?

  filieresS3    StrategicValueChain[] @relation("EngagementValueChains")
  deliveries    ServiceDelivery[]
  collectiveDeliveries CollectiveDelivery[]
  activities    Activity[]

  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  @@map("beneficiary_engagements")
}

model OutcomeIndicator {
  id          Int      @id @default(autoincrement())
  name        String   // ex: "Emplois créés", "Réduction CO2"
  unit        String   // ex: "unités", "tonnes", "%", "EUR"
  description String?  @db.Text
  impacts     Impact[]
  objectives  Objective[]           @relation("ObjectiveIndicators")
  dataQuality DataQualityDimension?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("outcome_indicators")
}

model Impact {
  id            Int                  @id @default(autoincrement())
  beneficiaryId Int
  beneficiary   Beneficiary          @relation(fields: [beneficiaryId], references: [id], onDelete: Cascade)
  indicatorId   Int
  indicator     OutcomeIndicator     @relation(fields: [indicatorId], references: [id], onDelete: Cascade)
  
  numericValue  Float?               // ex: 50000.0 (quantitative)
  textValue     String?              @db.Text // ex: "Plan d'action IA établi" (qualitative)
  
  territoryId   Int?
  territory     Territory?           @relation(fields: [territoryId], references: [id], onDelete: SetNull)
  
  valueChainId  Int?
  valueChain    StrategicValueChain? @relation("ImpactValueChains", fields: [valueChainId], references: [id], onDelete: SetNull)
  
  date          DateTime             @default(now())
  evidence      String?              @db.Text

  impactDimensionId Int?
  impactDimension   ImpactDimension?      @relation(fields: [impactDimensionId], references: [id], onDelete: SetNull)

  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  @@map("impacts")
}

model FundingInstrument {
  id             Int                   @id @default(autoincrement())
  name           String                // ex: "FEDER Wallonie", "Chèque Entreprises Cybersécurité"
  type           String                // ex: FEDER, Horizon Europe, Chèque Entreprise, Wallonie, Digital Europe
  description    String?               @db.Text
  
  strategies     Strategy[]            @relation("StrategyFunding")
  programs       Program[]             @relation("ProgramFunding")
  measures       Measure[]             @relation("MeasureFunding")
  initiatives    Initiative[]          @relation("InitiativeFunding")
  services       PublicService[]       @relation("ServiceFunding")
  beneficiaries  Beneficiary[]         @relation("BeneficiaryFunding")

  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  @@map("funding_instruments")
}

// ==========================================
// PIT v7.0 New Core Entities
// ==========================================

model Project {
  id              Int                   @id @default(autoincrement())
  code            String?               @unique
  name            String
  description     String?               @db.Text
  uri             String?               @unique
  startDate       DateTime?
  endDate         DateTime?
  status          String                @default("PLANNED") // PLANNED, ACTIVE, COMPLETED, CANCELLED
  
  programId       Int?
  program         Program?              @relation(fields: [programId], references: [id], onDelete: SetNull)
  
  initiativeId    Int?
  initiative      Initiative?           @relation(fields: [initiativeId], references: [id], onDelete: SetNull)
  beneficiaryId   Int?
  beneficiary     Beneficiary?          @relation("BeneficiaryProjects", fields: [beneficiaryId], references: [id], onDelete: SetNull)
  actionsNew      Action[]

  actions         ActionInstance[]
  organizations   Organization[]        @relation("ProjectOrganizations")
  ecosystems      Ecosystem[]           @relation("ProjectEcosystems")

  // Dimension relations
  transformationDimensions TransformationDimension[] @relation("ProjectTransformations")
  strategicDomains         StrategicDomainDimension[] @relation("ProjectStrategicDomains")
  capabilities             CapabilityDimension[]     @relation("ProjectCapabilities")
  impacts                  ImpactDimension[]         @relation("ProjectImpacts")
  knowledges               KnowledgeDimension[]       @relation("ProjectKnowledges")

  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  @@map("projects")
}

model Objective {
  id              Int                   @id @default(autoincrement())
  code            String?               @unique
  name            String
  description     String?               @db.Text
  uri             String?               @unique
  
  strategyId      Int?
  strategy        Strategy?             @relation(fields: [strategyId], references: [id], onDelete: SetNull)
  
  parentId        Int?
  parent          Objective?            @relation("ObjectiveHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children        Objective[]           @relation("ObjectiveHierarchy")

  indicators      OutcomeIndicator[]    @relation("ObjectiveIndicators")

  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  @@map("objectives")
}

// ==========================================
// PIT v7.0 Transversal Dimensions
// ==========================================

model TransformationDimension {
  id              Int                   @id @default(autoincrement())
  code            String                @unique // D, R, B, E, S, T
  name            String                // Demonstration, Readiness / Skills, Business, Ecosystem, Support, Technology
  description     String?               @db.Text
  uri             String?               @unique
  
  organizations   Organization[]        @relation("OrganizationTransformations")
  programs        Program[]             @relation("ProgramTransformations")
  projects        Project[]             @relation("ProjectTransformations")
  actionInstances ActionInstance[]      @relation("ActionTransformations")
  deliveries      ServiceDelivery[]     @relation("DeliveryTransformations")
  collectiveDeliveries CollectiveDelivery[] @relation("CollectiveTransformations")
  secondLineMissions SecondLineMission[]  @relation("MissionTransformations")
  services        PublicService[]       @relation("ServiceTransformations")
  journeys        Journey[]             @relation("JourneyTransformations")
  ecosystems      Ecosystem[]           @relation("EcosystemTransformations")
  activitiesNew   Activity[]           @relation("ActivityTransformationsNew")

  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  @@map("transformation_dimensions")
}

/// @deprecated
model StrategicDomainDimension {
  id              Int                         @id @default(autoincrement())
  code            String?                     @unique
  name            String
  level           String                      // DOMAIN, SUBDOMAIN
  description     String?                     @db.Text
  uri             String?                     @unique
  
  parentId        Int?
  parent          StrategicDomainDimension?   @relation("StrategicDomainHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children        StrategicDomainDimension[]  @relation("StrategicDomainHierarchy")

  valueChains     StrategicValueChain[]       // Links to S3 Value Chains
  
  organizations   Organization[]              @relation("OrganizationStrategicDomains")
  programs        Program[]                   @relation("ProgramStrategicDomains")
  projects        Project[]                   @relation("ProjectStrategicDomains")
  actionInstances ActionInstance[]            @relation("ActionStrategicDomains")
  deliveries      ServiceDelivery[]           @relation("DeliveryStrategicDomains")
  collectiveDeliveries CollectiveDelivery[]   @relation("CollectiveStrategicDomains")
  secondLineMissions SecondLineMission[]      @relation("MissionStrategicDomains")
  services        PublicService[]             @relation("ServiceStrategicDomains")
  journeys        Journey[]                   @relation("JourneyStrategicDomains")
  ecosystems      Ecosystem[]                 @relation("EcosystemStrategicDomains")

  createdAt       DateTime                    @default(now())
  updatedAt       DateTime                    @updatedAt

  @@map("strategic_domain_dimensions")
}

