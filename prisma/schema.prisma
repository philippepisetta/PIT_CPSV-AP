  ARRONDISSEMENT
  COMMUNE
  ECONOMIC_BASIN
  INNOVATION_DISTRICT
}

enum KnowledgeAssetType {
  GUIDE
  REFERENTIAL
  BENCHMARK
  STUDY
  PUBLICATION
  METHODOLOGY
  TOOLKIT
}

// ==========================================
// Strategic Governance Models
