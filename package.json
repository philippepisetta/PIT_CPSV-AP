{
  "name": "testing-cpsv-ap",
  "version": "1.0.0",
  "description": "Lab de test du modèle sémantique CPSV-AP (PIT Wallonie)",
  "main": "index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/src/server.js",
    "dev": "ts-node src/server.ts",
    "seed": "ts-node prisma/seed.ts",
    "seed:demo": "ts-node prisma/seed-demo-pit-v1.ts",
    "seed:ecosystem": "ts-node prisma/seed-ecosystem.ts",
    "seed:edih": "ts-node prisma/seed-edih-services.ts",
    "postinstall": "prisma generate",
    "pit:audit": "ts-node tests/pit-auditor/audit.ts",
    "pit:audit:prod": "cross-env PIT_TARGET_URL=https://pit-cpsv-ap.vercel.app ts-node tests/pit-auditor/audit.ts",
    "test:pit": "ts-node testing/pit-functional-agent/pit-test-agent.ts",
    "test:pit:headed": "npx playwright test -c testing/pit-functional-agent/playwright.config.ts --headed",
    "test:pit:report": "npx playwright show-report testing/pit-functional-agent/reports/playwright-html"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.14.0",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "compression": "^1.8.1",
    "express": "^5.2.1",
    "swagger-jsdoc": "^6.3.0",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@types/compression": "^1.8.1",
    "@types/express": "^5.0.6",
    "@types/node": "^20.12.12",
    "cross-env": "^10.1.0",
    "playwright": "^1.60.0",
    "prisma": "^5.14.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  }
}
