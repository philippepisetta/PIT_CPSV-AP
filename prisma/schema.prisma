  name        String // ex: "Emplois créés", "Réduction CO2"
  unit        String // ex: "unités", "tonnes", "%", "EUR"
  description String?               @db.Text
  impacts     Impact[]
  objectives  Objective[]           @relation("ObjectiveIndicators")
  dataQuality DataQualityDimension?

  aggregationType String @default("SUM") // SUM, AVG, COUNT

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("outcome_indicators")
}

model Impact {
  id            Int              @id @default(autoincrement())
  beneficiaryId Int
  beneficiary   Beneficiary      @relation(fields: [beneficiaryId], references: [id], onDelete: Cascade)
  indicatorId   Int
  indicator     OutcomeIndicator @relation(fields: [indicatorId], references: [id], onDelete: Cascade)

  numericValue Float? // ex: 50000.0 (quantitative)
  textValue    String? @db.Text // ex: "Plan d'action IA établi" (qualitative)

  territoryId Int?
  territory   Territory? @relation(fields: [territoryId], references: [id], onDelete: SetNull)

  valueChainId Int?
  valueChain   StrategicValueChain? @relation("ImpactValueChains", fields: [valueChainId], references: [id], onDelete: SetNull)

  date     DateTime @default(now())
  evidence String?  @db.Text

  impactDimensionId Int?
  impactDimension   ImpactDimension? @relation(fields: [impactDimensionId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("impacts")
}

model FundingInstrument {
  id          Int     @id @default(autoincrement())
  name        String // ex: "FEDER Wallonie", "Chèque Entreprises Cybersécurité"
  type        String // ex: FEDER, Horizon Europe, Chèque Entreprise, Wallonie, Digital Europe
  description String? @db.Text

  strategies    Strategy[]      @relation("StrategyFunding")
  programs      Program[]       @relation("ProgramFunding")
  measures      Measure[]       @relation("MeasureFunding")
  initiatives   Initiative[]    @relation("InitiativeFunding")
  services      PublicService[] @relation("ServiceFunding")
  beneficiaries Beneficiary[]   @relation("BeneficiaryFunding")

  callId        Int?
  call          FundingCall?            @relation(fields: [callId], references: [id], onDelete: Cascade)
  awards        FundingAward[]
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt

  @@map("funding_instruments")
}

