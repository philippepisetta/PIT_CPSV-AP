  // Liens stratégiques
  territories   Territory[]            @relation("TerritoryChallenges")
  filieres      Filiere[]              @relation("FiliereChallenges")
  ecosystems    Ecosystem[]            @relation("EcosystemChallenges2")
  risks         Risk[]                 @relation("ChallengeRisks")
  indicators    TerritorialIndicator[] @relation("ChallengeIndicators")
  observations  TerritorialObservation[] @relation("ChallengeObservations")
  journeys      Journey[]              @relation("ChallengeJourneys")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("territorial_challenges")
}

model ChallengeObjective {
